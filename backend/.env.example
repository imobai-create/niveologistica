# Connection string do Supabase (Settings → Database). Em serverless, prefira o pooler (porta 6543).
DATABASE_URL=postgresql://postgres:<senha>@db.<projeto>.supabase.co:5432/postgres

# Chave da Anthropic (NÃO expor no front).
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-sonnet-4-6

# Domínios autorizados a chamar a API. Em dev: http://localhost:5173
CORS_ORIGINS=http://localhost:5173
